extends ../layouts/default.pug

block main
  main.chat-layout
    include ../partials/sidebar.pug

    section.chat-list-panel
      .chat-list-panel__header
        h2 Danh sách bạn bè
        p Theo dõi trạng thái hoạt động và nhắn tin ngay.

      .chat-list
        each friend in allFriends
          article.list-card(
            class=String(friend.id) === String(activeFriendId) ? "active" : ""
            data-user-id=friend.id
            onclick=`window.location='/chat/friends?friendId=${friend.id}'`
          )
            .list-card__left
              .chat-avatar(class=friend.status === "online" ? "is-online" : "")= friend.avatar
              .list-card__info
                h4= friend.fullName
                p= friend.lastMessage
            .list-card__right
              button.btn.btn-sm.btn-primary(type="button" data-user-id=friend.id) Lưu trữ

    - var selectedFriend = allFriends.find((item) => String(item.id) === String(activeFriendId)) || allFriends[0]

    section.chat-main-panel(
      data-current-user-id=currentUserId
      data-active-friend-id=activeFriendId
      data-active-friend-avatar=selectedFriend ? selectedFriend.avatar : "?"
    )
      - var conversation
      - var isRoom = false

      if selectedFriend
        - conversation = { avatar: selectedFriend.avatar, name: selectedFriend.fullName, statusText: "Online • đang nhập..." }
      else
        - conversation = { avatar: "?", name: "Chưa chọn bạn bè", statusText: "" }

      header.chat-conversation-header
        .chat-conversation-header__left
          .chat-avatar(class=isRoom ? "chat-avatar--room" : "")= conversation.avatar
          .chat-conversation-header__meta
            h3= conversation.name
            if isRoom
              p #{conversation.members} thành viên
            else
              p= conversation.statusText

        .chat-conversation-header__actions
          button.btn-icon(type="button" aria-label="call")
            i.bi.bi-telephone
          button.btn-icon(type="button" aria-label="info")
            i.bi.bi-info-circle

      .chat-messages
        each chat in chats
          article.message-row(class=String(chat.senderId) === String(currentUserId) ? "is-me" : "")
            if String(chat.senderId) !== String(currentUserId)
              .chat-avatar.chat-avatar--sm= conversation.avatar

            .message-content
              .message-bubble= chat.content

              .message-meta
                span= new Date(chat.createdAt).toLocaleTimeString("vi-VN", { hour: "2-digit", minute: "2-digit" })

      form#chat-composer.chat-composer
        button.btn-icon(type="button")
          i.bi.bi-emoji-smile
        button.btn-icon(type="button")
          i.bi.bi-image
        input.form-control(
          type="text"
          name="content"
          placeholder="Nhập tin nhắn..."
          autocomplete="off"
        )
        button.btn.btn-primary(type="submit") Gửi
