extends ../layouts/default.pug

block main
  main.chat-layout
    include ../partials/sidebar.pug

    section.chat-list-panel
      .chat-list-panel__header
        h2 Lời mời đã gửi
        p Theo dõi lời mời kết bạn đang chờ phản hồi.
      .chat-list
        each user in users
          article.list-card
            .list-card__left
              .chat-avatar= user.avatar
              .list-card__info
                h4= user.fullName
                p= user.statusLabel
            .list-card__right
              button.btn.btn-sm.btn-outline-secondary.cancel-friend-btn(
                  type="button"
                  data-user-id=(user._id || user.id)
                ) Hủy lời mời

    section.chat-main-panel
      - const title = "Đang chờ phản hồi"
      - const description = "Danh sách bên trái hiển thị các lời mời bạn đã gửi đi."
      include ../partials/empty-state.pug
