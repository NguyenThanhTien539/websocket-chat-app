extends ../layouts/default.pug

block main
  main.chat-layout
    include ../partials/sidebar.pug

    section.chat-list-panel
      .chat-list-panel__header
        h2 Lời mời đã nhận
        p Chấp nhận hoặc từ chối lời mời kết bạn.
      .chat-list
        each user in users
          - const mode = "received"
          article.list-card
            .list-card__left
              .chat-avatar= user.avatar
              .list-card__info
                h4= user.fullName
                p= user.statusLabel
            .list-card__right
              if mode === "received"
                button.btn.btn-sm.btn-primary(type="button") Chấp nhận
                button.btn.btn-sm.btn-light(type="button") Từ chối
              else
                button.btn.btn-sm.btn-outline-secondary(type="button") Hủy lời mời

    section.chat-main-panel
      - const title = "Quản lý lời mời"
      - const description = "Chọn người dùng bên trái để xem chi tiết và thao tác nhanh."
      include ../partials/empty-state.pug