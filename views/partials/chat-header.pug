header.chat-conversation-header
  .chat-conversation-header__left
    .chat-avatar(class=isRoom ? "chat-avatar--room" : "")= conversation.avatar
    .chat-conversation-header__meta
      h3= conversation.name
      if isRoom
        p #{conversation.members} thành viên
      else
        p= conversation.statusText

  .chat-conversation-header__actions
    button.btn-icon(type="button" aria-label="call")
      i.bi.bi-telephone
    button.btn-icon(type="button" aria-label="info")
      i.bi.bi-info-circle
